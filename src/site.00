const nav=[['About','/about'],['Research','/research'],['Projects','/projects'],['People','/people'],['Publications','/publications'],['Collaborate','/collaborate'],['Support','/support'],['Contact','/contact']];
const esc=s=>s.replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
const hero=(title,intro)=>`<section class="page-hero"><div class="shell"><h1>${title}</h1><p>${intro}</p></div></section>`;
const heading=(title,body='')=>`<div class="section-heading"><h2>${title}</h2>${body?`<p>${body}</p>`:''}</div>`;
const card=(title,body,label='')=>`<article class="card">${label?`<div class="eyebrow">${label}</div>`:''}<h3>${title}</h3><p>${body}</p></article>`;
const pages={
'/':()=>`<section class="hero"><div class="shell"><div class="eyebrow">Religious Cognition Collaborative</div><h1>Advancing the study of religion and the mind.</h1><p>We bring researchers together to investigate how religious beliefs, experiences, practices, and representations emerge, function, and change.</p><div class="actions"><a class="button primary" href="/research">Explore Our Research</a><a class="button secondary" href="/people">Meet the Collaborative</a></div></div></section>
<section class="section"><div class="shell">${heading('Religion is a complex cognitive phenomenon.','Religious cognition draws on perception, memory, emotion, social understanding, embodiment, imagination, and culture. No single discipline can explain it adequately. The Religious Cognition Collaborative develops and supports projects that integrate complementary theories, methods, and forms of expertise.')}<div class="grid four">${card('Religious Belief','How people represent supernatural agents, sacred realities, doctrines, religious identities, and other religious concepts.')}${card('Religious Experience','How religious and spiritual experiences arise, are interpreted, and influence thought, emotion, and behavior.')}${card('Brain and Behavior','How cognitive and neural systems contribute to religious belief, practice, experience, and decision-making.')}${card('Development and Transmission','How religious cognition is learned, communicated, revised, and expressed across communities and the lifespan.')}</div></div></section>
<section class="section alt"><div class="shell">${heading('Research organized around the question.','RCC forms project teams around clearly defined research questions. Each project brings together the investigators, methods, and institutional resources needed for that question, while the Collaborative provides continuity, coordination, and an organizational home.')}<a class="button dark" href="/projects">View Current Projects</a></div></section>
<section class="section"><div class="shell"><div class="callout"><h2>Better questions require broader collaboration.</h2><p>We welcome conversations with researchers, institutions, funders, and students interested in rigorous interdisciplinary work on religion and cognition.</p><a class="button primary" href="/collaborate">Collaborate With Us</a></div></div></section>`,
'/about':()=>`${hero('About the Collaborative','The Religious Cognition Collaborative is an interdisciplinary research organization devoted to the rigorous study of religious cognition. We connect researchers across institutions and fields to develop focused projects, combine complementary expertise, and produce scholarship that is both methodologically strong and intellectually open.')}
<section class="section"><div class="shell"><div class="grid two">${card('Our Mission','Our mission is to advance rigorous interdisciplinary research on the cognitive, psychological, neural, social, and cultural processes involved in religious belief, experience, and behavior.')}${card('Our Vision','We aim to build a durable research network in which scholars across institutions, disciplines, and traditions can develop strong projects, share expertise, and produce work that no single discipline or research group could accomplish alone.')}</div></div></section>
<section class="section alt"><div class="shell">${heading('What We Do','RCC develops research questions, assembles project teams, supports grant development, coordinates research activity, and helps move projects from initial concept through analysis, publication, and public communication.')}<ul class="list-clean"><li>Develop interdisciplinary research projects.</li><li>Connect investigators with complementary expertise.</li><li>Support grant development and research administration.</li><li>Coordinate project planning, data work, and scholarly outputs.</li><li>Share findings through publications, presentations, resources, and public scholarship.</li></ul></div></section>
<section class="section"><div class="shell">${heading('Our Approach')}<div class="grid two">${card('Rigorous inquiry','We prioritize clear research questions, appropriate methods, transparent reasoning, and conclusions that remain proportionate to the evidence.')}${card('Interdisciplinary integration','Religious cognition operates across multiple levels of explanation. Our projects may draw on cognitive science, psychology, neuroscience, philosophy, religious studies, anthropology, and related fields when those perspectives are relevant to the question.')}${card('Religious and philosophical openness','RCC is nonconfessional. It does not promote or privilege any religious tradition. We welcome researchers across religious, philosophical, and disciplinary backgrounds and appro