se"><h2>What support may fund</h2><ul><li>Participant recruitment and compensation.</li><li>Data access, collection, storage, and preparation.</li><li>Research software, analytic tools, and technical services.</li><li>Research assistants, analysts, and project coordination.</li><li>Travel, scholarly meetings, and collaborative workshops.</li><li>Open-access publication and public dissemination.</li></ul></div><div class="card"><h3>How support is administered</h3><p>The Religious Cognition Collaborative operates as a sponsored research program. Grants and contributions supporting RCC will be received and administered by the sponsoring 501(c)(3) nonprofit and used for approved charitable and research purposes in accordance with applicable agreements and organizational policies.</p><div class="notice">Donation routing and sponsor-approved tax language will be added before accepting contributions.</div></div></div></div></section>`,
'/contact':()=>`${hero('Contact','Contact RCC regarding research collaboration, project development, funding, media inquiries, or general organizational questions. Please include enough information for us to understand the purpose of your message.')}
<section class="section"><div class="shell"><div class="grid two"><div class="prose"><h2>Research inquiries</h2><p><a href="mailto:barrostheology@gmail.com">barrostheology@gmail.com</a></p><p class="notice">RCC is a research organization and does not provide mental health diagnosis, treatment, crisis support, or individual medical advice.</p></div>${form('Send a Message',['Name','Email','Institution or Organization','Reason for Contact','Subject'],'Send Message')}</div></div></section>`,
'/privacy':()=>`${hero('Privacy','This page describes the launch-state privacy practices of the Religious Cognition Collaborative website.')}
<section class="section"><div class="shell prose"><h2>Information you provide</h2><p>When you contact RCC by email or through a form, you may provide your name, email address, institutional affiliation, and the contents of your message. This information is used to review and respond to your inquiry.</p><h2>Website forms</h2><p>At launch, forms open a draft email in the visitor’s email application. Form information is not stored by this website itself. This may change if a dedicated form platform is added, in which case this policy will be updated.</p><h2>Analytics and cookies</h2><p>No optional analytics or advertising cookies are intentionally configured in this initial build. Hosting providers may process technical information necessary to deliver and secure the site.</p><h2>Contact</h2><p>Questions about this policy may be sent to <a href="mailto:barrostheology@gmail.com">barrostheology@gmail.com</a>.</p></div></section>`
};
function form(title,fields,button){return `<form class="card form mailto-form"><h3>${title}</h3><div class="form-grid">${fields.map((f,i)=>`<div class="field ${i===fields.length-1?'wide':''}"><label>${f}<input name="${f}" ${f==='Email'?'type="email"':''} required></label></div>`).join('')}</div><div class="field"><label>Message<textarea name="Message" required></textarea></label></div><button class="button dark" type="submit">${button}</button><p class="form-status" aria-live="polite"></p></form>`}
function setupNav(){const desktop=document.querySelector('.desktop-nav'),mobile=document.querySelector('.mobile-nav'),footer=document.querySelector('.footer-nav');const links=[...nav];desktop.innerHTML=links.map(([l,h])=>`<a href="${h}">${l}</a>`).join('');mobile.innerHTML=`<a href="/">Home</a>`+links.map(([l,h])=>`<a href="${h}">${l}</a>`).join('');footer.innerHTML=links.concat([['Privacy','/privacy']]).map(([l,h])=>`<a href="${h}">${l}</a>`).join('');document.querySelector('.menu-button').addEventListener('click',e=>{const open=e.currentTarget.getAttribute('aria-expanded')==='true';e.currentTarget.setAttribute('aria-expanded',String(!open));mobile.hidden=open});}
function setupForms(){document.querySelectorAll('.mailto-form').forEach(f=>f.addEventListener('submit',e=>{e.preventDefault();const data=new FormData(f);const subject=data.get('Subject')||data.get('Proposed Collaboration')||'RCC website inquiry';const body=[...data.entries()].map(([k,v])=>`${k}: ${v}`).join('\n\n');window.location.href=`mailto:barrostheology@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;f.querySelector('.form-status').textContent='Your email application should open with a prepared message.'}))}
function render(){setupNav();let path=location.pathname.replace(/\/$/,'')||'/';const page=pages[path]||(()=>`${hero('Page Not Found','The page you requested may have moved, changed, or no longer exists.')}<section class="section"><div class="shell"><a class="button dark" href="/">Return Home</a></div></section>`);document.getElementById('content').innerHTML=page();document.querySelectorAll('.desktop-nav a').forEach(a=>{if(a.getAttribute('href')===path)a.classList.add('active')});setupForms();window.scrollTo(0,0)}
render();
